# GitHub OAuth App (github.com/settings/developers → OAuth Apps → New)
# Callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Random secret: openssl rand -base64 32
AUTH_SECRET=

# Your GitHub username — only this account can log in
GITHUB_USERNAME=

# Fine-grained PAT (github.com/settings/tokens → Fine-grained tokens)
# Scope: single repo (your notes repo), permissions: Contents (read/write) + Metadata (read)
GITHUB_PAT=

# Your GitHub username and the notes repo name
GITHUB_OWNER=
GITHUB_REPO=notes
